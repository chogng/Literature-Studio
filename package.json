{
  "name": "journal-reader",
  "private": true,
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev:electron": "npm run build:electron && wait-on tcp:1420 && cross-env ELECTRON_RENDERER_URL=http://localhost:1420 node dist-electron/launch.js dist-electron/main.js",
    "dev:web": "vite --config vite.web.config.ts",
    "build": "npm run build:electron && tsc && vite build",
    "start": "npm run build:electron && node dist-electron/launch.js dist-electron/main.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-switch": "^1.2.6",
    "cheerio": "^1.1.2",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^37.5.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.0",
    "wait-on": "^8.0.5"
  }
}
