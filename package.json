{
  "name": "journal-reader",
  "private": true,
  "version": "0.1.0",
  "main": "dist-electron/code/electron-main/main.js",
  "type": "module",
  "scripts": {
    "predev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./kill-dev-ports.ps1",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev:electron:build": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on tcp:1420 file:dist-electron/code/electron-main/main.js && cross-env ELECTRON_RENDERER_URL=http://localhost:1420 nodemon --watch dist-electron --ext js --delay 2000ms --signal SIGTERM dist-electron/code/electron-main/launch.js dist-electron/code/electron-main/main.js",
    "dev:electron": "concurrently -k \"npm:dev:electron:build\" \"npm:dev:electron:run\"",
    "dev:web": "vite --config vite.web.config.ts",
    "check:i18n": "node scripts/check-i18n-keys.mjs",
    "build": "npm run build:electron && tsc && vite build",
    "start": "npm run build:electron && node dist-electron/code/electron-main/launch.js dist-electron/code/electron-main/main.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-switch": "^1.2.6",
    "cheerio": "^1.1.2",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^37.5.1",
    "nodemon": "^3.1.10",
    "typescript": "~5.9.3",
    "vite": "^7.2.0",
    "wait-on": "^8.0.5"
  }
}
